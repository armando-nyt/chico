{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["DOM", "ES2022"],
    "strict": true,
    "noEmit": true,
    "types": ["node"],
    "verbatimModuleSyntax": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "demo/**/*.ts", "test/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
